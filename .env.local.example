# ───────────────────────────────────────────────────────────────────
# MOCKMATE - ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to '.env.local' and fill in your actual live keys.
# ───────────────────────────────────────────────────────────────────

# Convex Database Configurations
CONVEX_DEPLOYMENT=your_convex_deployment_id_here
NEXT_PUBLIC_CONVEX_URL=your_convex_url_here
NEXT_PUBLIC_CONVEX_SITE_URL=your_convex_site_url_here

# Clerk Authentication Shields
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# AI Integration & Pipeline Engines (Optional Fallbacks)
AKOOL_API_KEY=your_akool_key_here
ARCJET_KEY=your_arcjet_key_here
N8N_WEBHOOK_URL=your_n8n_url_here
OPENAI_API_KEY=your_openai_key_here